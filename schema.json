  function searchKnowledgeBase(mode: "vector" | "skill" | "openapi" | "docs", skillName?: "ai-model-nodejs" | "ai-model-web" | "ai-model-wechat" | "auth-http-api" | "auth-nodejs" | "auth-tool" | "auth-web" | "auth-wechat" | "cloud-functions" | "cloud-storage-web" | "cloudbase-agent-ts" | "cloudbase-platform" | "cloudrun-development" | "data-model-creation" | "http-api" | "miniprogram-development" | "no-sql-web-sdk" | "no-sql-wx-mp-sdk" | "relational-database-tool" | "relational-database-web" | "spec-workflow" | "ui-design" | "web-development", apiName?: "mysqldb" | "functions" | "auth" | "cloudrun" | "storage", action?: "listModules" | "listModuleDocs" | "findByName" | "readDoc" | "searchDocs", moduleName?: string);
