  function manageFunctions(action: "createFunction" | "updateFunctionCode" | "updateFunctionConfig" | "invokeFunction" | "createFunctionTrigger" | "deleteFunctionTrigger" | "createLayerVersion" | "deleteLayerVersion" | "attachLayer" | "detachLayer" | "updateFunctionLayers", func?: unknown, functionRootPath?: string, force?: boolean, functionName?: string);
