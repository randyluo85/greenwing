{
  "permissions": {
    "openapi": [
      "cloudPay.unifiedOrder",
      "cloudPay.queryOrder",
      "cloudPay.refund"
    ]
  },
  "timeout": 20,
  "cloudPay": true,
  "triggers": [
    {
      "name": "payCallback",
      "type": "http",
      "config": {
        "methods": [
          "POST"
        ],
        "authRequired": false
      }
    }
  ]
}