/* pages/event-detail/event-detail.wxss */

.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 封面区 */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 800rpx;
}

.cover {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
}

.cover-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
}

.cover-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.4;
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.cover-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding:0 0 10px 0;
}

.cover-tag {
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.tag-status { background: #14b8a6; color: #ffffff; }
.tag-enrolled { background: #2563EB; color: #ffffff; }
.tag-full { background: #FEF3C7; color: #D97706; }
.tag-closed { background: #F1F5F9; color: #94A3B8; }
.tag-points { border: 1rpx solid #fbbf24; color: #fbbf24; }
.tag-paid { background: #EFF6FF; color: #2563EB; }
.tag-free { background: #ECFDF5; color: #059669; }

/* 信息卡片 */
.info-card {
  position: relative;
  margin: -32rpx 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 2rpx 16rpx -4rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: rgba(20, 184, 166, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.info-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.info-text-wrap {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.info-primary {
  font-size: 30rpx;
  font-weight: 500;
  color: #1E293B;
}

.info-sub {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 6rpx;
}

/* 卡片标签 */
.card-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #1E293B;
  display: block;
  margin-bottom: 16rpx;
}

/* 报名条件 */
.condition-card {
  padding: 24rpx;
  margin: 16rpx 0 0 0;
}

.condition-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.condition-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.condition-item:last-child {
  border-bottom: none;
}

.condition-text {
  font-size: 26rpx;
  color: #1E293B;
}

.condition-status {
  font-size: 24rpx;
  font-weight: bold;
}

.condition-status.ok { color: #059669; }
.condition-status.fail { color: #EF4444; }

.price-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #2563EB;
}

/* 活动详情 */
.detail-card {
  padding: 24rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #64748B;
  line-height: 2;
}

/* 底部浮动操作栏 */
.bottom-bar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.bottom-bar {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 40rpx -10rpx rgba(0, 0, 0, 0.12);
}

.bottom-left {
  display: flex;
  flex-direction: column;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.price-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #14b8a6;
  line-height: 1;
}

.price-unit {
  font-size: 24rpx;
  color: #14b8a6;
  margin-left: 4rpx;
}

.enrolled-info {
  display: flex;
  align-items: center;
}

.enrolled-text {
  font-size: 22rpx;
  color: #94A3B8;
}

.enroll-btn {
  padding: 20rpx 56rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.enroll-btn.disabled {
  background: var(--surface);
  color: #94A3B8;
  box-shadow: none;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.hidden { display: none !important; }

.modal-card {
  width: 560rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  animation: fadeInScale 0.3s ease-out both;
}

.modal-top {
  width: 100%;
  height: 260rpx;
  overflow: hidden;
}

.modal-top-img {
  width: 100%;
  height: 100%;
}

.modal-bottom {
  padding: 48rpx 40rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.modal-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

.modal-hint-amber {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: bold;
  margin-top: 8rpx;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.modal-close-text {
  color: rgba(255,255,255,0.8);
  font-size: 28rpx;
}

/* 真实姓名填写弹窗 */
.name-modal-card {
  width: 600rpx;
  padding: 0;
}

.name-modal-header {
  padding: 40rpx 32rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f3f4f6;
}

.name-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  display: block;
}

.name-modal-subtitle {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

.name-modal-body {
  padding: 32rpx;
}

.name-input-group {
  margin-bottom: 24rpx;
}

.name-input-label {
  font-size: 26rpx;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
}

.name-input-field {
  width: 100%;
  height: 80rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
}

.name-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.name-modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.name-modal-btn-cancel {
  background: #f3f4f6;
  color: #64748b;
}

.name-modal-btn-confirm {
  background: var(--primary, #14b8a6);
  color: #ffffff;
}

/* 评论讨论区 */
.comment-card {
  padding: 24rpx;
}

.comment-list {
  margin-top: 16rpx;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f1f5f9;
}

.comment-body {
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 500;
  color: #1E293B;
}

.comment-time {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.comment-content {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.6;
  word-break: break-all;
}

.comment-empty {
  padding: 48rpx 0;
  text-align: center;
}

.comment-empty-text {
  font-size: 26rpx;
  color: #94A3B8;
}

.comment-load-more {
  padding: 24rpx 0;
  text-align: center;
}

.comment-load-more-text {
  font-size: 24rpx;
  color: #14b8a6;
}

.comment-post-trigger {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border-radius: 999rpx;
  border: 2rpx solid #e2e8f0;
}

.comment-post-trigger-text {
  font-size: 26rpx;
  color: #94A3B8;
}

.comment-input-area {
  margin-top: 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
}

.comment-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.6;
  box-sizing: border-box;
}

.comment-input-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.comment-char-count {
  font-size: 22rpx;
  color: #94A3B8;
}

.comment-submit-btn {
  background: #14b8a6;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.comment-submit-btn.disabled {
  background: #e2e8f0;
  color: #94A3B8;
}
