.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* Avatar */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 48rpx;
  background: #ffffff;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx -4rpx rgba(0,0,0,0.1);
}

.avatar-camera {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  background: var(--primary);
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.camera-text {
  color: #ffffff;
  font-size: 28rpx;
}

.avatar-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Form */
.form-section {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

.form-field {
  margin-bottom: 32rpx;
}

.form-row {
  display: flex;
  gap: 32rpx;
}

.form-field-half {
  flex: 1;
}

.field-label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  margin-left: 16rpx;
}

.field-label.required::before {
  content: '*';
  color: var(--danger, #ef4444);
  margin-right: 4rpx;
}

.field-input {
  background: #ffffff;
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.field-textarea {
  background: #ffffff;
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-main);
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-input {
  display: flex;
  align-items: center;
}

.field-input-disabled {
  background: #f9fafb;
  color: var(--text-muted);
}

.field-input-phone {
  flex: 1;
}

.phone-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.auth-phone-btn {
  background: var(--primary);
  color: #ffffff;
  font-size: 26rpx;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  width: auto;
  align-self: flex-start;
}

.auth-phone-btn::after {
  border: none;
}

.field-help {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  margin-left: 16rpx;
}

/* Footer */
.footer {
  padding-top: 80rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Save Bar */
.save-bar {
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.save-btn::after {
  border: none;
}
