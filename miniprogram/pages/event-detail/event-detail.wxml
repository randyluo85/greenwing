<!--pages/event-detail/event-detail.wxml-->
<view class="page" wx:if="{{event}}">

  <!-- 封面区: 图片 + 渐变遮罩 + 标题叠加 -->
  <view class="cover-wrap">
    <image src="{{event.cover_image || '/images/event.jpg'}}" mode="aspectFill" class="cover" />
    <view class="cover-overlay"></view>
    <view class="cover-content">
      <text class="cover-title">{{event.title}}</text>
      <view class="cover-tags">
        <!-- 平台状态 -->
        <text class="cover-tag tag-enrolled" wx:if="{{isEnrolled}}">已报名</text>
        <text class="cover-tag tag-status" wx:elif="{{platformStatus === 'open'}}">报名中</text>
        <text class="cover-tag tag-full" wx:elif="{{platformStatus === 'full'}}">名额已满</text>
        <text class="cover-tag tag-closed" wx:elif="{{platformStatus === 'closed'}}">报名已结束</text>
        <!-- 报名模式 -->
        <text class="cover-tag tag-points" wx:if="{{event.registration_mode === 'points_only'}}">{{event.points_cost}}积分</text>
        <text class="cover-tag tag-paid" wx:if="{{event.registration_mode === 'paid'}}">{{priceText}}元</text>
        <text class="cover-tag tag-free" wx:if="{{event.registration_mode === 'free'}}">免费</text>
      </view>
    </view>
  </view>

  <!-- 信息卡片 (上移覆盖封面底部) -->
  <view class="info-card">
    <!-- 时间 -->
    <view class="info-row">
      <view class="info-icon-wrap">
        <image src="/images/svg/clock.svg" class="info-icon-img" />
      </view>
      <view class="info-text-wrap">
        <text class="info-primary">{{formattedTime}}</text>
        <text class="info-sub" wx:if="{{formattedTimeSub}}">{{formattedTimeSub}}</text>
      </view>
    </view>
    <!-- 地点 -->
    <view class="info-row" wx:if="{{event.location}}">
      <view class="info-icon-wrap">
        <image src="/images/svg/location.svg" class="info-icon-img" />
      </view>
      <view class="info-text-wrap">
        <text class="info-primary">{{event.location}}</text>
        <text class="info-sub" wx:if="{{event.address}}">{{event.address}}</text>
      </view>
    </view>
    <!-- 主讲人 -->
    <view class="info-row" wx:if="{{event.speaker}}">
      <view class="info-icon-wrap">
        <image src="/images/svg/user.svg" class="info-icon-img" />
      </view>
      <view class="info-text-wrap">
        <text class="info-primary">{{event.speaker}}</text>
        <text class="info-sub" wx:if="{{event.speaker_title}}">{{event.speaker_title}}</text>
      </view>
    </view>
    <!-- 名额 -->
    <view class="info-row">
      <view class="info-icon-wrap">
        <image src="/images/svg/users.svg" class="info-icon-img" />
      </view>
      <view class="info-text-wrap">
        <text class="info-primary">{{event.quota || '不限'}}人</text>
        <text class="info-sub">已报名{{event.enrolled_count || 0}}人</text>
      </view>
    </view>
  </view>

  <!-- 报名条件 -->
  <view class="card condition-card" wx:if="{{event.registration_mode !== 'free'}}">
    <text class="card-label">报名条件</text>
    <view class="condition-list">
      <view class="condition-item" wx:if="{{event.registration_mode === 'points_only'}}">
        <text class="condition-text">需要 {{event.points_cost}} 积分</text>
        <text class="condition-status {{userPoints >= event.points_cost ? 'ok' : 'fail'}}">
          当前 {{userPoints}} 积分
        </text>
      </view>
      <view class="condition-item" wx:if="{{event.tier_threshold && event.tier_threshold !== 'none'}}">
        <text class="condition-text">需要{{tierText}}及以上</text>
        <text class="condition-status {{tierOk ? 'ok' : 'fail'}}">{{tierOk ? '已满足' : '未满足'}}</text>
      </view>
      <view class="condition-item" wx:if="{{event.registration_mode === 'paid'}}">
        <text class="condition-text">报名费</text>
        <text class="price-text">{{priceText}} 元</text>
      </view>
    </view>
  </view>

  <!-- 活动详情 -->
  <view class="card detail-card">
    <text class="card-label">活动详情</text>
    <rich-text nodes="{{event.description || '暂无详情'}}" class="detail-content" />
  </view>

  <!-- 评论讨论区 (仅已报名用户可见) -->
  <view class="card comment-card" wx:if="{{isEnrolled}}">
    <text class="card-label">活动讨论 ({{commentTotal}})</text>

    <!-- 评论列表 -->
    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <view class="comment-item" wx:for="{{comments}}" wx:key="_id">
        <image class="comment-avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="comment-body">
          <view class="comment-header">
            <text class="comment-nickname">{{item.nickname}}</text>
            <text class="comment-time">{{item.timeAgo}}</text>
          </view>
          <text class="comment-content">{{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="comment-empty" wx:if="{{comments.length === 0 && !commentsLoading}}">
      <text class="comment-empty-text">还没有人讨论，来说点什么吧</text>
    </view>

    <!-- 加载更多 -->
    <view class="comment-load-more" wx:if="{{commentHasMore}}" bindtap="onLoadMoreComments">
      <text class="comment-load-more-text">{{commentsLoading ? '加载中...' : '查看更多评论'}}</text>
    </view>

    <!-- 发表评论输入区 -->
    <view class="comment-input-area" wx:if="{{showCommentInput}}">
      <textarea
        class="comment-textarea"
        placeholder="说点什么..."
        value="{{commentText}}"
        bindinput="onCommentInput"
        maxlength="500"
        auto-height
        focus="{{showCommentInput}}"
      />
      <view class="comment-input-actions">
        <text class="comment-char-count">{{commentText.length}}/500</text>
        <view class="comment-submit-btn {{commentPosting ? 'disabled' : ''}}" bindtap="onPostComment">
          <text>{{commentPosting ? '发送中...' : '发送'}}</text>
        </view>
      </view>
    </view>

    <!-- 发表评论触发条 -->
    <view class="comment-post-trigger" wx:if="{{!showCommentInput}}" bindtap="onToggleCommentInput">
      <text class="comment-post-trigger-text">发表评论...</text>
    </view>
  </view>

  <!-- 底部浮动操作栏 -->
  <view class="bottom-bar-wrap">
    <view class="bottom-bar">
      <view class="bottom-left">
        <view class="price-row" wx:if="{{event.registration_mode === 'paid'}}">
          <text class="price-value">{{priceText}}</text>
          <text class="price-unit">元</text>
        </view>
        <view class="price-row" wx:elif="{{event.registration_mode === 'points_only'}}">
          <text class="price-value">{{event.points_cost}}</text>
          <text class="price-unit">积分</text>
        </view>
        <view class="enrolled-info">
          <text class="enrolled-text">已报名{{event.enrolled_count || 0}}人</text>
        </view>
      </view>
      <view class="btn-primary enroll-btn {{canEnroll ? '' : 'disabled'}}" bindtap="onEnroll">
        <text>{{enrollBtnText}}</text>
      </view>
    </view>
  </view>

</view>

<!-- 真实姓名填写弹窗 -->
<view class="modal-mask {{showNameModal ? '' : 'hidden'}}" bindtap="closeNameModal">
  <view class="modal-card name-modal-card" catchtap>
    <view class="name-modal-header">
      <text class="name-modal-title">完善报名信息</text>
      <text class="name-modal-subtitle">请填写真实姓名，用于活动签到</text>
    </view>
    <view class="name-modal-body">
      <view class="name-input-group">
        <text class="name-input-label">真实姓名 *</text>
        <input
          class="name-input-field"
          placeholder="请输入真实姓名"
          value="{{enrollRealName}}"
          bindinput="onEnrollNameInput"
        />
      </view>
      <view class="name-input-group">
        <text class="name-input-label">联系电话</text>
        <input
          class="name-input-field"
          placeholder="选填，便于活动通知"
          value="{{enrollContactPhone}}"
          bindinput="onEnrollPhoneInput"
          type="number"
          maxlength="11"
        />
      </view>
    </view>
    <view class="name-modal-footer">
      <view class="name-modal-btn name-modal-btn-cancel" bindtap="closeNameModal">
        <text>取消</text>
      </view>
      <view class="name-modal-btn name-modal-btn-confirm" bindtap="confirmEnrollWithName">
        <text>确认报名</text>
      </view>
    </view>
  </view>
</view>

<!-- 报名成功弹窗 -->
<view class="modal-mask {{showSuccessModal ? '' : 'hidden'}}" bindtap="closeSuccessModal">
  <view class="modal-card" catchtap>
    <view class="modal-top">
      <image src="/images/sign.png" mode="aspectFill" class="modal-top-img" />
    </view>
    <view class="modal-bottom">
      <text class="modal-title">报名成功</text>
      <text class="modal-hint">可在【我的】里面查看</text>
      <text class="modal-hint-amber">活动当日可凭券码参加活动</text>
    </view>
  </view>
  <view class="modal-close" bindtap="closeSuccessModal">
    <text class="modal-close-text">x</text>
  </view>
</view>
