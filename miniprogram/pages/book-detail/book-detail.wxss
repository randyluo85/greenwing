.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
  font-size: 26rpx;
  color: var(--text-muted);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-content {
  padding: 24rpx;
}

/* Main Card */
.main-card {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx -4rpx rgba(0,0,0,0.04);
}

.cover-row {
  display: flex;
}

.cover-img {
  width: 270rpx;
  height: 360rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f1f5f9;
  border: 1rpx solid #f3f4f6;
}

.meta-col {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}

.book-title {
  font-size: 38rpx;
  font-weight: bold;
  color: var(--text-main);
  line-height: 1.4;
}

.rating-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.rating-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.rating-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--primary);
  margin-left: 8rpx;
}

.star-row {
  margin-top: 4rpx;
  display: flex;
  gap: 2rpx;
  font-size: 24rpx;
  color: #f59e0b;
}

.star-full {
  color: #f59e0b;
}

.star-half {
  color: #fbbf24;
  opacity: 0.65;
}

.star-empty {
  color: #d1d5db;
}

.meta-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.5;
}

/* Divider - gray bar matching prototype */
.section-divider {
  width: 64rpx;
  height: 4rpx;
  background: #e5e7eb;
  border-radius: 2rpx;
  margin: 48rpx 0 40rpx 0;
}

/* Summary */
.summary-section {
  padding: 0;
}

.summary-header {
  display: flex;
  align-items: center;
  position: relative;
  margin-bottom: 24rpx;
}

.summary-bar-deco {
  width: 28rpx;
  height: 26rpx;
  background: #5eead4;
  opacity: 0.6;
  border-radius: 4rpx;
  position: absolute;
  top: 6rpx;
  left: -4rpx;
}

.summary-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
  position: relative;
  padding-left: 8rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.8;
  text-indent: 2em;
}
