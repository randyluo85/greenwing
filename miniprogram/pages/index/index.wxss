/* pages/index/index.wxss */

.page {
  padding-bottom: 24rpx;
  background: var(--bg);
  min-height: 100vh;
}

/* 工具栏: Logo + 搜索 + 消息 */
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
}

.toolbar-logo {
  width: 168rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.toolbar-search {
  flex: 1;
  margin: 0 20rpx;
  height: 64rpx;
  background: #f5f6f8;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.toolbar-search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.toolbar-search-text {
  font-size: 26rpx;
  color: #94a3b8;
  margin-left: 12rpx;
}

.toolbar-bell {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.toolbar-bell-icon {
  width: 40rpx;
  height: 40rpx;
}

.toolbar-dot {
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  width: 12rpx;
  height: 12rpx;
  background: #f97316;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* Banner */
.banner-wrap {
  position: relative;
  padding: 0 24rpx;
}

.banner {
  width: 100%;
  height: 340rpx;
}

.banner-slide {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  pointer-events: none;
}

.banner-text {
  position: absolute;
  bottom: 24rpx;
  left: 28rpx;
  right: 100rpx;
  z-index: 2;
}

.banner-title {
  display: block;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.4;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
}

.banner-subtitle {
  display: block;
  color: rgba(255,255,255,0.85);
  font-size: 22rpx;
  line-height: 1.4;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.3);
}

.banner-dots {
  position: absolute;
  bottom: 28rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 3;
}

.banner-dot {
  width: 12rpx;
  height: 4rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  transition: all 0.3s ease;
}

.banner-dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: #ffffff;
}

.banner-placeholder {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}

.banner-logo {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 12rpx;
}

.banner-ph-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* Content */
.content {
  padding: 0 24rpx;
}

/* Action Grid */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 16rpx;
  height: 340rpx;
  margin: 24rpx 0 32rpx;
}

.action-card {
  border-radius: 24rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx -4rpx rgba(0,0,0,0.04);
}

/* Main sign-in card */
.action-card-main {
  grid-row: 1 / 3;
  background: linear-gradient(135deg, #5eead4, #ccfbf1);
}

.action-main-inner {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.action-main-top {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-main-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #115e59;
}

.action-main-arrow {
  background: #0f766e;
}

.action-main-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.sign-info {
  display: flex;
  flex-direction: column;
}

.sign-label {
  font-size: 20rpx;
  color: #0f766e;
  margin-bottom: 4rpx;
}

.sign-count-row {
  display: flex;
  align-items: baseline;
}

.sign-number {
  font-size: 68rpx;
  font-weight: bold;
  color: #0f766e;
  line-height: 1;
}

.sign-unit {
  font-size: 22rpx;
  color: #0f766e;
  margin-left: 4rpx;
}

.sign-btn {
  background: #14b8a6;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 8rpx rgba(20, 184, 166, 0.3);
}

.sign-btn.signed {
  background: rgba(20, 184, 166, 0.4);
  box-shadow: none;
}

.action-deco {
  position: absolute;
  top: 8rpx;
  right: 4rpx;
  width: 128rpx;
  height: 128rpx;
  z-index: 0;
}

/* Amber card */
.action-card-amber {
  background: linear-gradient(135deg, #fde68a, #fef3c7);
}

.action-sub-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  gap: 16rpx;
}

.action-sub-title {
  font-size: 28rpx;
  font-weight: bold;
}

.action-amber-text { color: #b45309; }
.action-blue-text { color: #1d4ed8; }

.action-arrow {
  width: 50rpx;
  height: 32rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chevron-right {
  width: 10rpx;
  height: 10rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
}

.action-arrow .chevron-right {
  margin-left: -2rpx;
}

.chevron-gray {
  color: var(--text-secondary);
  border-width: 2rpx;
}

.action-amber-arrow { background: #f59e0b; }
.action-blue-arrow { background: #3b82f6; }

.action-card-blue {
  background: linear-gradient(135deg, #dbeafe, #eff6ff);
}

.action-deco-sm {
  position: absolute;
  top: 50%;
  right: 16rpx;
  transform: translateY(-50%);
  width: 112rpx;
  height: 112rpx;
  z-index: 0;
}

/* Section */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
}

.section-icon {
  width: 28rpx;
  height: 32rpx;
  margin-left: 8rpx;
}

.section-more {
  font-size: 22rpx;
  color: var(--text-secondary);
  border: 1rpx solid #e5e7eb;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* Event List */
.event-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.event-item {
  display: flex;
}

.event-cover-wrap {
  width: 200rpx;
  height: 270rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f1f5f9;
}

.event-cover {
  width: 100%;
  height: 100%;
}

.event-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  padding: 4rpx 0;
}

.event-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
  line-height: 1.4;
}

.event-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 12rpx;
}

.event-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.event-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-status { padding: 4rpx 12rpx; border-radius: 4rpx; }
.tag-status.status-active { background: #14b8a6; color: #ffffff; }
.tag-status.status-closed { background: #f97316; color: #ffffff; }
.tag-status.status-ended { background: #94a3b8; color: #ffffff; }
.tag-points { color: var(--accent); border: 1rpx solid var(--accent); border-radius: 6rpx; }
.tag-paid { color: #3b82f6; border: 1rpx solid #3b82f6; border-radius: 6rpx; }

.event-meta-list {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.event-meta-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Book Horizontal Scroll */
.book-scroll {
  width: 100%;
  white-space: nowrap;
}

.book-scroll-inner {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.book-item {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  flex-shrink: 0;
}

.book-cover-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f1f5f9;
  box-shadow: 0 2rpx 8rpx -2rpx rgba(0,0,0,0.1);
}

.book-cover {
  width: 100%;
  height: 100%;
}

.book-rating {
  position: absolute;
  top: 0;
  left: 0;
  background: var(--accent);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: bold;
  padding: 4rpx 10rpx;
  border-bottom-right-radius: 12rpx;
}

.book-title {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-top: 12rpx;
}

.book-author {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.book-stars {
  margin-top: 4rpx;
  display: flex;
  gap: 2rpx;
}
.book-stars .star {
  font-size: 20rpx;
}
.book-stars .star-full {
  color: #f59e0b;
}
.book-stars .star-half {
  color: #fbbf24;
  opacity: 0.65;
}
.book-stars .star-empty {
  color: #d1d5db;
}

/* Sign-in Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.hidden { display: none !important; }

.modal-card {
  width: 560rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.modal-top { width: 100%; height: 260rpx; background: #ffffff; }
.modal-top-img { width: 100%; height: 260rpx; }

.modal-bottom {
  background: #ffffff;
  padding: 48rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.modal-points {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  color: var(--accent);
  font-weight: bold;
  margin-bottom: 16rpx;
}

.points-plus { font-size: 36rpx; margin-right: 4rpx; padding-bottom: 8rpx; }
.points-num { font-size: 80rpx; line-height: 1; letter-spacing: -2rpx; }
.points-unit { font-size: 22rpx; padding-bottom: 12rpx; margin-left: 8rpx; }

.modal-sub { font-size: 24rpx; color: var(--text-muted); }

.modal-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
}

.modal-close-text { color: rgba(255,255,255,0.8); font-size: 28rpx; }
