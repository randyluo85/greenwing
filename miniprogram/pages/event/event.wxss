.page {
  background: #f5f6f8;
  min-height: 100vh;
  padding-bottom: 24rpx;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0 20rpx;
  font-size: 30rpx;
  color: #94A3B8;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #14b8a6;
  font-weight: bold;
  border-bottom-color: #14b8a6;
}

/* 区块 */
.section { margin-top: 24rpx; }

.section-header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-bar {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.bar-teal { background: #1ab6a2; }
.bar-gray { background: #9ca3af; }

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  letter-spacing: 2rpx;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
  margin-left: auto;
}

/* 往期活动标题 */
.past-header {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx 0;
  margin-bottom: 20rpx;
}

.past-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #64748B;
  margin-left: 16rpx;
}

/* 活动列表 */
.event-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 24rpx; }

/* 活动卡片 */
.event-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx -8rpx rgba(0,0,0,0.1);
}

.card-past, .card-history { opacity: 0.9; }

/* 卡片头部 */
.card-header { padding: 32rpx; color: #ffffff; }

.bg-teal { background: #1ab6a2; }
.bg-gray { background: #9ca3af; }

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.header-date { display: flex; flex-direction: column; }

.date-text {
  font-size: 34rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.time-text {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.badge-open { background: #ccfbf1; color: #0f766e; }
.badge-full { background: #fee2e2; color: #dc2626; }
.badge-registered { background: #ccfbf1; color: #0f766e; }
.badge-ended { background: #e5e7eb; color: #4b5563; }

.card-title {
  font-size: 38rpx;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.card-divider {
  height: 2rpx;
  background: rgba(255,255,255,0.2);
  margin-bottom: 24rpx;
}

.card-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  opacity: 0.9;
  letter-spacing: 2rpx;
}

.location-icon { margin-right: 8rpx; font-size: 20rpx; }
.location-text { letter-spacing: 4rpx; }

.card-bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-meta-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quota-text { font-size: 22rpx; opacity: 0.8; }
.points-cost { font-size: 22rpx; background: rgba(255,255,255,0.2); padding: 2rpx 12rpx; border-radius: 8rpx; }

/* 卡片底部 */
.card-footer {
  background: #ffffff;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-time {
  font-size: 22rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

.btn-detail {
  padding: 10rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  color: #6b7280;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.btn-detail:active { background: #f9fafb; }

.btn-enroll {
  padding: 10rpx 24rpx;
  background: #1ab6a2;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.btn-enroll:active { background: #0d9488; }
.btn-enroll.disabled { background: #94a3b8; }

.btn-cancel-rsvp {
  padding: 10rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  color: #6b7280;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.btn-cancel-rsvp:active { background: #f9fafb; }
.btn-cancel-rsvp.disabled { opacity: 0.5; }

.btn-ticket {
  padding: 10rpx 24rpx;
  background: #1ab6a2;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8rpx;
  letter-spacing: 2rpx;
}

.btn-ticket:active { background: #0d9488; }
.qr-icon { font-size: 22rpx; }

.btn-review {
  padding: 10rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  color: #6b7280;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.btn-review:active { background: #f9fafb; }

.empty-hint {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #94A3B8;
}

/* 加载 */
.loading-wrap { padding: 40rpx 0; text-align: center; }
.loading-text { font-size: 24rpx; color: #94A3B8; }
.empty-state { display: flex; justify-content: center; padding: 120rpx 0; }
.empty-text { font-size: 28rpx; color: #94A3B8; }
.load-end { text-align: center; padding: 32rpx 0; font-size: 24rpx; color: #94A3B8; }

/* ========== 入场凭证弹窗 ========== */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(0,0,0,0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.modal-card {
  width: 100%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
  animation: modalFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes modalFadeIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.modal-top-img { width: 100%; height: 240rpx; }

.modal-body {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title { font-size: 34rpx; font-weight: bold; color: #1E293B; margin-bottom: 32rpx; }

.qr-area {
  width: 320rpx; height: 320rpx;
  background: #f9fafb;
  border: 1rpx solid #f3f4f6;
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
}

.qr-canvas { width: 288rpx; height: 288rpx; }

.verify-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.verify-label { font-size: 30rpx; color: #1E293B; font-weight: 500; margin-right: 16rpx; }

.verify-code-box { background: #f3f4f6; padding: 8rpx 24rpx; border-radius: 8rpx; }

.verify-code {
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  color: #1E293B;
  font-family: monospace;
}

.dashed-line {
  width: 100%;
  border-top: 3rpx dashed #d1d5db;
  position: relative;
  margin-bottom: 32rpx;
}

.circle-left, .circle-right {
  position: absolute;
  width: 32rpx; height: 32rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  top: -18rpx;
}

.circle-left { left: -56rpx; }
.circle-right { right: -56rpx; }

.modal-hint { text-align: center; display: flex; flex-direction: column; align-items: center; }
.hint-text { font-size: 22rpx; color: #6b7280; font-weight: 500; letter-spacing: 2rpx; }
.hint-highlight { font-size: 22rpx; color: #f59e0b; font-weight: bold; letter-spacing: 2rpx; margin-top: 8rpx; }

.modal-close {
  margin-top: 48rpx;
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.8);
  display: flex; align-items: center; justify-content: center;
}

.close-icon { color: rgba(255,255,255,0.8); font-size: 28rpx; }
