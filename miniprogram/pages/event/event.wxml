<!--pages/event/event.wxml-->
<view class="page">

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab {{currentTab === 'mine' ? 'active' : ''}}" bindtap="switchTab" data-tab="mine">我的活动</view>
    <view class="tab {{currentTab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">活动列表</view>
  </view>

  <!-- 活动列表 Tab -->
  <view wx:if="{{currentTab === 'list'}}">
    <!-- 可报名活动 -->
    <view class="section" wx:if="{{events.length}}">
      <view class="event-list">
        <view class="event-card" wx:for="{{events}}" wx:key="_id" wx:if="{{!item._isPast}}">
          <view class="card-header bg-teal">
            <view class="header-top">
              <view class="header-date">
                <text class="date-text">{{item._formattedDate}}</text>
                <text class="time-text">{{item._formattedTime}}</text>
              </view>
              <view class="status-badge badge-open" wx:if="{{item.enrolled_count < item.quota && !item._enrolled}}">报名中</view>
              <view class="status-badge badge-registered" wx:elif="{{item._enrolled}}">已报名</view>
              <view class="status-badge badge-full" wx:else>名额已满</view>
            </view>
            <text class="card-title">{{item.title}}</text>
            <view class="card-divider"></view>
            <view class="card-bottom-row">
              <view class="card-location">
                <text class="location-icon">@</text>
                <text class="location-text">{{item.location || '线上'}}</text>
              </view>
              <view class="card-meta-right">
                <text class="quota-text">{{item.enrolled_count || 0}}/{{item.quota || '?'}} 名额</text>
                <text class="points-cost" wx:if="{{item.registration_mode === 'points_only'}}">{{item.points_cost || 0}}积分</text>
              </view>
            </view>
          </view>
          <view class="card-footer">
            <view class="footer-actions">
              <view class="btn-detail" bindtap="goDetail" data-id="{{item._id}}">
                <text>查看详情</text>
              </view>
              <view class="btn-enroll {{item._enrolled || item.enrolled_count >= item.quota ? 'disabled' : ''}}" bindtap="goDetail" data-id="{{item._id}}">
                <text>{{item._enrolled ? '已报名' : item.enrolled_count >= item.quota ? '名额已满' : '立即报名'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 往期活动 -->
    <view class="section" wx:if="{{events.length}}">
      <view class="past-header">
        <view class="section-bar bar-gray"></view>
        <text class="past-title">往期活动</text>
      </view>
      <view class="event-list">
        <view class="event-card card-past card-compact" wx:for="{{events}}" wx:key="_id" wx:if="{{item._isPast}}">
          <view class="compact-header">
            <text class="compact-title">{{item.title}}</text>
            <view class="status-badge badge-ended">已结束</view>
          </view>
          <view class="compact-footer">
            <view class="compact-info">
              <view class="compact-info-item">
                <text>{{item._formattedDate}} {{item._formattedTime}}</text>
              </view>
              <view class="compact-info-item">
                <text>{{item.location || '线上'}}</text>
              </view>
            </view>
            <view class="btn-detail btn-compact" bindtap="goDetail" data-id="{{item._id}}">
              <text>查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && events.length === 0}}">
      <text class="empty-text">暂无活动</text>
    </view>

    <view class="load-end" wx:if="{{!hasMore && events.length > 0 && !loading}}">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 我的活动 Tab -->
  <view wx:if="{{currentTab === 'mine'}}">
    <!-- 待参加活动 -->
    <view class="section">
      <view class="section-header">
        <view class="section-bar bar-teal"></view>
        <text class="section-title">待参加活动</text>
        <text class="section-count" wx:if="{{pendingList.length}}">共 {{pendingList.length}} 场</text>
      </view>
      <view class="event-list" wx:if="{{pendingList.length}}">
        <view class="event-card" wx:for="{{pendingList}}" wx:key="_id">
          <view class="card-header bg-teal">
            <view class="header-top">
              <view class="header-date">
                <text class="date-text">{{item.event._formattedDate || ''}}</text>
                <text class="time-text">{{item.event._formattedTime || ''}}</text>
              </view>
              <view class="status-badge badge-registered">已报名</view>
            </view>
            <text class="card-title">{{item.event.title || '活动'}}</text>
            <view class="card-divider"></view>
            <view class="card-location">
              <text class="location-icon">@</text>
              <text class="location-text">{{item.event.location || '线上'}}</text>
            </view>
          </view>
          <view class="card-footer">
            <text class="footer-time">{{item.event._enrollDate || ''}}</text>
            <view class="footer-actions">
              <view class="btn-cancel-rsvp {{cancelledIds.indexOf(item._id) >= 0 ? 'disabled' : ''}}"
                bindtap="cancelEnroll" data-id="{{item._id}}">
                <text>{{cancelledIds.indexOf(item._id) >= 0 ? '已取消' : '取消报名'}}</text>
              </view>
              <view class="btn-ticket" bindtap="showTicket" data-code="{{item.verify_code}}">
                <text class="qr-icon">#</text>
                <text>入场凭证</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-hint" wx:if="{{!myLoading && pendingList.length === 0}}">
        <text>暂无待参加活动</text>
      </view>
    </view>

    <!-- 历史足迹 -->
    <view class="section">
      <view class="section-header">
        <view class="section-bar bar-gray"></view>
        <text class="section-title">历史足迹</text>
      </view>
      <view class="event-list" wx:if="{{historyList.length}}">
        <view class="event-card card-history card-compact" wx:for="{{historyList}}" wx:key="_id">
          <view class="compact-header">
            <text class="compact-title">{{item.event.title || '活动'}}</text>
            <view class="status-badge badge-ended">已结束</view>
          </view>
          <view class="compact-footer">
            <view class="compact-info">
              <view class="compact-info-item">
                <text class="compact-icon">@</text>
                <text>{{item.event._formattedDate || ''}} {{item.event._formattedTime || ''}}</text>
              </view>
              <view class="compact-info-item">
                <text class="compact-icon">地</text>
                <text>{{item.event.location || '线上'}}</text>
              </view>
            </view>
            <view class="btn-detail btn-compact" bindtap="goDetail" data-id="{{item.event._id}}">
              <text>活动回顾</text>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-hint" wx:if="{{!myLoading && historyList.length === 0}}">
        <text>暂无历史活动</text>
      </view>
    </view>
  </view>

</view>

<!-- 入场凭证弹窗 -->
<view class="modal-overlay" wx:if="{{showTicketModal}}" bindtap="closeTicket">
  <view class="modal-card" catchtap="noop">
    <image src="/images/ticket.png" mode="aspectFill" class="modal-top-img" />
    <view class="modal-body">
      <text class="modal-title">入场核销</text>
      <view class="qr-area">
        <canvas canvas-id="qrcode" class="qr-canvas"></canvas>
      </view>
      <view class="verify-row">
        <text class="verify-label">核销码</text>
        <view class="verify-code-box">
          <text class="verify-code">{{ticketCode}}</text>
        </view>
      </view>
      <view class="dashed-line">
        <view class="circle-left"></view>
        <view class="circle-right"></view>
      </view>
      <view class="modal-hint">
        <text class="hint-text">可在【活动核销】里面查看</text>
        <text class="hint-highlight">活动当日凭券码或券号参加活动</text>
      </view>
    </view>
  </view>
  <view class="modal-close" bindtap="closeTicket">
    <text class="close-icon">x</text>
  </view>
</view>
