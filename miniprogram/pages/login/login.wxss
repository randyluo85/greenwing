.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 0 80rpx 120rpx;
  background: #ffffff;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 35vh;
}

.logo {
  width: 192rpx;
  height: 192rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #111827;
  letter-spacing: 1rpx;
}

.deco-line {
  width: 64rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
  margin: 24rpx 0;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  letter-spacing: 12rpx;
  font-weight: 500;
  text-transform: uppercase;
}

.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-login-btn {
  width: 100%;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid #f1f5f9;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  box-shadow: 0 4rpx 20rpx -4rpx rgba(0,0,0,0.05);
}

.wx-login-btn::after {
  border: none;
}

.wx-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(7,193,96,0.25);
}

.wx-icon-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.terms-text {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 80rpx;
  text-align: center;
  line-height: 1.6;
}
