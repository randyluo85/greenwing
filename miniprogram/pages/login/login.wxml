<view class="login-page">
  <view class="login-content">
    <image src="/images/logo.png" mode="aspectFit" class="logo" />
    <text class="title">青翼读书会</text>
    <view class="deco-line"></view>
    <text class="subtitle">赋能你的知识</text>
  </view>

  <view class="login-actions">
    <button class="wx-login-btn btn-active" bindtap="onWxLogin" loading="{{loading}}">
      <view class="wx-icon-wrap">
        <image src="/images/icons/wechat.svg" class="wx-icon-img" wx:if="{{!loading}}" />
        <text class="wx-icon-text" wx:else>W</text>
      </view>
      <text>微信授权登录</text>
    </button>
    <view class="security-divider">
      <view class="line"></view>
      <text class="security-text">安全可靠</text>
      <view class="line"></view>
    </view>
    <text class="terms-text">登录即代表您同意\n《用户协议》与《隐私保护指引》</text>
  </view>
</view>
