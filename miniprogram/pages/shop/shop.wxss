.shop-page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shop-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shop-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: var(--surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.shop-icon {
  width: 80rpx;
  height: 80rpx;
}

.shop-title {
  font-size: 32rpx;
  font-weight: normal;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.shop-desc {
  font-size: 26rpx;
  color: var(--text-muted);
}
