.page { min-height: 100vh; background: #fff; }
.search-header { display: flex; align-items: center; padding: 20rpx 30rpx; background: #fff; position: sticky; top: 0; z-index: 100; border-bottom: 1rpx solid #f0f0f0; }
.search-bar { flex: 1; display: flex; align-items: center; background: #f5f6f8; height: 72rpx; border-radius: 36rpx; padding: 0 24rpx; }
.search-icon { width: 32rpx; height: 32rpx; opacity: 0.5; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; height: 100%; color: #333; }
.clear-icon { width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #999; }
.cancel-btn { font-size: 30rpx; color: #333; margin-left: 24rpx; }

.search-history { padding: 40rpx 30rpx; }
.history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.history-title { font-size: 30rpx; font-weight: normal; color: #333; }
.history-clear { font-size: 26rpx; color: #999; }
.history-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.history-tag { padding: 10rpx 24rpx; background: #f5f6f8; border-radius: 8rpx; font-size: 26rpx; color: #333; }

.search-results { padding: 20rpx 30rpx; }
.loading { text-align: center; color: #999; font-size: 26rpx; padding: 40rpx 0; }
.empty-state { text-align: center; color: #999; font-size: 28rpx; padding: 100rpx 0; }

.event-list { margin-top: 20rpx; }
.event-item { display: flex; margin-bottom: 30rpx; }
.event-cover-wrap { width: 200rpx; height: 150rpx; border-radius: 12rpx; overflow: hidden; margin-right: 20rpx; flex-shrink: 0; }
.event-cover { width: 100%; height: 100%; }
.event-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; padding: 4rpx 0; }
.event-title { font-size: 30rpx; font-weight: normal; color: #333; line-height: 1.4; }
.event-meta-list { display: flex; flex-direction: column; gap: 8rpx; margin-top: 10rpx; }
.event-meta-text { font-size: 24rpx; color: #94a3b8; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
