.login-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 80rpx;
  background: #ffffff;
  box-sizing: border-box;
  position: relative;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 400rpx;
  height: 180rpx;
}

.deco-line {
  width: 64rpx;
  height: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
  margin: 24rpx 0 24rpx 0;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  letter-spacing: 12rpx;
  font-weight: 500;
  text-transform: uppercase;
  margin-top: 24rpx;
}


.login-actions {
  position: absolute;
  bottom: 130rpx;
  left: 80rpx;
  right: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-login-btn {
  width: 100%;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid #f1f5f9;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
  box-shadow: 0 4rpx 20rpx -4rpx rgba(0,0,0,0.05);
}

.wx-login-btn::after {
  border: none;
}

.wx-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(7,193,96,0.25);
}

.wx-icon-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

.terms-text {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.security-divider {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 60rpx;
  padding: 0 40rpx;
}

.security-divider .line {
  flex: 1;
  height: 1rpx;
  background: #f1f5f9;
}

.security-text {
  font-size: 20rpx;
  color: #cbd5e1;
  margin: 0 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.wx-icon-img {
  width: 48rpx;
  height: 48rpx;
}
