/* 青翼读书会 - 全局样式 */

/* 设计令牌 */
page {
  --primary: #14b8a6;
  --primary-dark: #0d9488;
  --secondary: #2dd4bf;
  --accent: #f59e0b;
  --bg: #f5f6f8;
  --surface: #f0fdfa;
  --text-main: #1E293B;
  --text-secondary: #64748B;
  --text-muted: #94A3B8;
  --border: #F1F5F9;
  --radius: 8rpx;
  --radius-sm: 4rpx;

  font-family: 'PingFang SC', -apple-system, 'Helvetica Neue', sans-serif;
  background-color: var(--bg);
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx -4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(241, 245, 249, 0.5);
}

/* 主色按钮 */
.btn-primary {
  background: linear-gradient(to bottom, var(--secondary) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx -6rpx rgba(20, 184, 166, 0.5);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.96);
}

/* 次要按钮 */
.btn-secondary {
  background: var(--surface);
  color: var(--primary);
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 48rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-primary {
  background: #ECFDF5;
  color: #059669;
}

.tag-amber {
  background: #FFFBEB;
  color: #D97706;
}

.tag-blue {
  background: #EFF6FF;
  color: #2563EB;
}

.tag-gray {
  background: #F1F5F9;
  color: #94A3B8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}

/* Loading 动画组件 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
  height: 24rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: var(--primary);
  border-radius: 50%;
  opacity: 0.4;
  animation: loadingPulse 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(1) { animation-delay: 0s; }
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes loadingPulse {
  0%, 80%, 100% {
    opacity: 0.4;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 按压反馈 */
.btn-active {
  transition: transform 0.15s, opacity 0.15s;
}

.btn-active:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 玻璃拟态 */
.glass-surface {
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.animate-fade-up {
  animation: fadeInUp 0.4s ease-out both;
}

.animate-fade-scale {
  animation: fadeInScale 0.3s ease-out both;
}

.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.1s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.2s; }
.stagger-5 { animation-delay: 0.25s; }

/* 无滚动条 */
.no-scrollbar ::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
