<!--pages/my-events/my-events.wxml-->
<view class="page">

  <!-- 待参加活动 -->
  <view class="section">
    <view class="section-header">
      <view class="section-bar bar-teal"></view>
      <text class="section-title">待参加活动</text>
      <text class="section-count" wx:if="{{pendingList.length}}">共 {{pendingList.length}} 场</text>
    </view>

    <view class="event-list" wx:if="{{pendingList.length}}">
      <view class="event-card" wx:for="{{pendingList}}" wx:key="_id">
        <view class="card-header bg-teal">
          <view class="header-top">
            <view class="header-date">
              <text class="date-text">{{item.event._formattedDate || ''}}</text>
              <text class="time-text">{{item.event._formattedTime || ''}}</text>
            </view>
            <view class="status-badge badge-soon" wx:if="{{item._isToday}}">即将开始</view>
            <view class="status-badge badge-registered" wx:else>已报名</view>
          </view>
          <text class="card-title">{{item.event.title || '活动'}}</text>
          <view class="card-divider"></view>
          <view class="card-location">
            <text class="location-icon">@</text>
            <text class="location-text">{{item.event.location || '线上'}}</text>
          </view>
        </view>
        <view class="card-footer">
          <text class="footer-time">{{item.event._enrollDate || ''}}</text>
          <view class="footer-actions">
            <view class="btn-cancel-rsvp {{cancelledIds.indexOf(item._id) >= 0 ? 'disabled' : ''}}"
              bindtap="cancelEnroll" data-id="{{item._id}}">
              <text>{{cancelledIds.indexOf(item._id) >= 0 ? '已取消' : '取消报名'}}</text>
            </view>
            <view class="btn-ticket" bindtap="showTicket" data-code="{{item.verify_code}}" data-id="{{item._id}}">
              <text class="qr-icon">#</text>
              <text>入场凭证</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-hint" wx:if="{{!loading && pendingList.length === 0}}">
      <text>暂无待参加活动</text>
    </view>
  </view>

  <!-- 历史足迹 -->
  <view class="section">
    <view class="section-header">
      <view class="section-bar bar-gray"></view>
      <text class="section-title">历史足迹</text>
    </view>

    <view class="event-list" wx:if="{{historyList.length}}">
      <view class="event-card card-history card-compact" wx:for="{{historyList}}" wx:key="_id">
        <view class="compact-header">
          <text class="compact-title">{{item.event.title || '活动'}}</text>
          <view class="status-badge badge-ended" wx:if="{{item.status === 'cancelled'}}">已取消</view>
          <view class="status-badge badge-ended" wx:elif="{{item.status === 'verified'}}">已核销</view>
          <view class="status-badge badge-ended" wx:else>已结束</view>
        </view>
        <view class="compact-footer">
          <view class="compact-info">
            <view class="compact-info-item">
              <text>{{item.event._formattedDate || ''}} {{item.event._formattedTime || ''}}</text>
            </view>
            <view class="compact-info-item">
              <text>{{item.event.location || '线上'}}</text>
            </view>
          </view>
          <view class="btn-detail btn-compact" bindtap="goDetail" data-id="{{item.event._id}}">
            <text>活动回顾</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-hint" wx:if="{{!loading && historyList.length === 0}}">
      <text>暂无历史活动</text>
    </view>
  </view>

  <view class="load-end" wx:if="{{!loading && pendingList.length === 0 && historyList.length === 0}}">
    <text>暂无活动记录</text>
  </view>

</view>

<!-- 入场凭证弹窗 -->
<view class="modal-overlay" wx:if="{{showTicketModal}}" bindtap="closeTicket">
  <view class="modal-card" catchtap="noop">
    <!-- 顶部装饰图 -->
    <image src="/images/ticket.png" mode="aspectFill" class="modal-top-img" />
    <!-- 内容区 -->
    <view class="modal-body">
      <text class="modal-title">入场核销</text>
      <!-- QR码区域 -->
      <view class="qr-area">
        <image wx:if="{{qrcodeUrl}}" src="{{qrcodeUrl}}" class="qr-image" mode="aspectFit" />
        <view wx:elif="{{qrLoading}}" class="qr-loading">
          <text class="qr-loading-text">生成中...</text>
        </view>
        <view wx:else class="qr-fallback">
          <text class="fallback-text">请使用下方核销码</text>
        </view>
      </view>
      <!-- 核销码 -->
      <view class="verify-row">
        <text class="verify-label">核销码</text>
        <view class="verify-code-box">
          <text class="verify-code">{{ticketCode}}</text>
        </view>
      </view>
      <!-- 虚线分隔 -->
      <view class="dashed-line">
        <view class="circle-left"></view>
        <view class="circle-right"></view>
      </view>
      <!-- 提示文字 -->
      <view class="modal-hint">
        <text class="hint-text">可在【活动核销】里面查看</text>
        <text class="hint-highlight">活动当日凭券码或券号参加活动</text>
      </view>
    </view>
  </view>
  <!-- 关闭按钮 -->
  <view class="modal-close" bindtap="closeTicket">
    <text class="close-icon">x</text>
  </view>
</view>
