.page { 
  position: relative;
  min-height: 100vh;
  background: #f3f4f6;
}

/* 顶部背景图 */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  z-index: 0;
}

.main-content {
  position: relative;
  z-index: 1;
  padding-bottom: 80rpx;
}

/* 概览区 */
.overview-section {
  padding: 40rpx 40rpx 60rpx;
}

.overview-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.overview-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #78350f;
  font-weight: normal;
}

.star-icon-wrap {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #fbbf24;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.icon-text {
  font-size: 18rpx;
  color: #fff;
}

.rules-btn {
  background: rgba(255, 255, 255, 0.4);
  color: #78350f;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-weight: normal;
}

/* 大数字展示 */
.large-points-display {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 60rpx;
}

.coin-icon-wrap {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fbbf24;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.coin-symbol {
  font-size: 20rpx;
  color: #ffffff;
}

.points-value {
  font-size: 110rpx;
  font-weight: normal;
  color: #000000;
  line-height: 1;
  letter-spacing: -2rpx;
  font-family: Impact, "Arial Narrow Bold", sans-serif;
}

/* 列表区 */
.list-section {
  padding: 0 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: normal;
  color: #111827;
  margin-bottom: 24rpx;
}

.glass-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0 32rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.log-item:last-child {
  border-bottom: none;
}

.log-left {
  display: flex;
  flex-direction: column;
}

.log-desc {
  font-size: 30rpx;
  color: #111827;
  font-weight: normal;
}

.log-time {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 6rpx;
}

.log-amount {
  font-size: 36rpx;
  font-weight: normal;
}

.log-amount.income { color: #f59e0b; }
.log-amount.expense { color: #9ca3af; }

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.load-end { 
  text-align: center; 
  padding: 40rpx 0; 
  font-size: 24rpx; 
  color: #9ca3af; 
}
