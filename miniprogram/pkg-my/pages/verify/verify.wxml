<!--pages/verify/verify.wxml-->
<view class="page">

  <view class="scan-area" wx:if="{{!result}}">
    <view class="scan-card card">
      <text class="scan-title">扫码核销</text>
      <text class="scan-desc">点击下方按钮扫描用户的核销码</text>
      <view class="scan-btn btn-primary" bindtap="startScan">
        <text>扫描核销码</text>
      </view>
    </view>

    <view class="manual-card card">
      <text class="manual-title">手动输入核销码</text>
      <view class="manual-input-wrap">
        <input class="manual-input" placeholder="请输入6位核销码，如 6UYWGU" bindinput="onCodeInput" value="{{manualCode}}" />
        <view class="btn-primary manual-btn" bindtap="manualVerify">
          <text>核销</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核销结果 -->
  <view class="result-area" wx:if="{{result}}">
    <!-- 成功 -->
    <block wx:if="{{result.success}}">
      <view class="result-card card success">
        <view class="result-icon">
          <text>OK</text>
        </view>
        <text class="result-title">核销成功</text>
      </view>
      <view class="info-card card" wx:if="{{verifiedInfo}}">
        <view class="info-row">
          <text class="info-label">真实姓名</text>
          <text class="info-value">{{verifiedInfo.real_name || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">手机号</text>
          <text class="info-value">{{verifiedInfo.contact_phone || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">用户昵称</text>
          <text class="info-value">{{verifiedInfo.nickname || '未知'}}</text>
        </view>
      </view>
    </block>
    <!-- 失败 -->
    <block wx:else>
      <view class="result-card card fail">
        <view class="result-icon">
          <text>!</text>
        </view>
        <text class="result-title">核销失败</text>
        <text class="result-desc">{{result.message}}</text>
      </view>
    </block>
    <view class="btn-primary retry-btn" bindtap="resetVerify">
      <text>继续核销</text>
    </view>
  </view>

</view>
