.page { background: var(--bg); min-height: 100vh; padding: 24rpx; }

.scan-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  text-align: center;
}

.scan-title { font-size: 34rpx; font-weight: bold; color: #1E293B; margin-bottom: 12rpx; }

.scan-desc { font-size: 26rpx; color: #64748B; margin-bottom: 32rpx; }

.scan-btn { padding: 24rpx 80rpx; }

.manual-card {
  padding: 28rpx;
  margin-top: 20rpx;
}

.manual-title { font-size: 28rpx; font-weight: bold; color: #1E293B; margin-bottom: 16rpx; display: block; }

.manual-input-wrap {
  display: flex;
  gap: 16rpx;
}

.manual-input {
  flex: 1;
  background: var(--bg);
  border: 1rpx solid var(--surface);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.manual-btn { padding: 16rpx 32rpx; flex-shrink: 0; }

.result-area { display: flex; flex-direction: column; align-items: center; }

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  text-align: center;
}

.result-card.success { border: 2rpx solid #059669; }
.result-card.fail { border: 2rpx solid #EF4444; }

.result-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.success .result-icon { background: #ECFDF5; color: #059669; }
.fail .result-icon { background: #FEF2F2; color: #EF4444; }

.result-title { font-size: 34rpx; font-weight: bold; color: #1E293B; margin-bottom: 8rpx; }

.result-desc { font-size: 26rpx; color: #64748B; }

.retry-btn { margin-top: 32rpx; padding: 20rpx 60rpx; }

.info-card {
  margin-top: 24rpx;
  padding: 28rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid #f1f5f9;
}

.info-label {
  font-size: 26rpx;
  color: #64748B;
}

.info-value {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}
