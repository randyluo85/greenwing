.container {
  padding: 30rpx;
  background: #f8fafc;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  margin-bottom: 20rpx;
}

.time {
  font-size: 24rpx;
  color: #64748b;
}

.status {
  font-size: 26rpx;
  font-weight: normal;
}

.content {
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.label {
  color: #64748b;
  width: 140rpx;
  flex-shrink: 0;
}

.value {
  color: #334155;
  flex: 1;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-price {
  color: #ef4444;
  font-weight: normal;
}

.text-red {
  color: #ef4444;
}

.text-orange {
  color: #f59e0b;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  border-top: 1rpx solid #f1f5f9;
  padding-top: 20rpx;
}

.btn {
  margin: 0;
  padding: 0 30rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: transparent;
}

.btn::after {
  display: none;
}

.btn-outline {
  color: #64748b;
  border: 1rpx solid #cbd5e1;
}

.btn-primary {
  /* 渐变背景：从左上到右下，亮色到深色 */
  background: linear-gradient(135deg, #2dd4bf 0%, #14b8a6 50%, #0d9488 100%);
  color: #fff;
  /* 立体阴影：外部投影 + 内部高光 */
  box-shadow:
    0 6rpx 16rpx rgba(20, 184, 166, 0.4),
    0 3rpx 6rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transform: translateY(0);
  transition: all 0.2s ease;
}

.btn-primary:active {
  /* 按下时：渐变变暗、阴影缩小、轻微下沉 */
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 50%, #0f766e 100%);
  box-shadow:
    0 3rpx 8rpx rgba(20, 184, 166, 0.3),
    0 1rpx 3rpx rgba(0, 0, 0, 0.1),
    inset 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
  transform: translateY(2rpx);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}
